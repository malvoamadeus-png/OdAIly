{
  "manifest_version": 3,
  "name": "Odaily快讯助手",
  "version": "1.0.0",
  "description": "Odaily 快讯 AI 助手工具",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab"
  ],
  "action": {
    "default_title": "打开 AI 助手"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content-script.js"
      ]
    }
  ]
}

