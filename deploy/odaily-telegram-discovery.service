[Unit]
Description=OdAIly Telegram-first non-mainstream media discovery worker
After=network-online.target odaily-local-pipeline.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/OdAIly
EnvironmentFile=-/opt/OdAIly/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/OdAIly/.venv/bin/python backend/src/main.py telegram-discovery-worker
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
