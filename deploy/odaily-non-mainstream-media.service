[Unit]
Description=OdAIly non-mainstream media capture worker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/OdAIly
EnvironmentFile=-/opt/OdAIly/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/OdAIly/.venv/bin/python backend/src/main.py non-mainstream-media-worker
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
